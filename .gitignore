# Documenter build output + resolved docs environment (regenerated each build)
/docs/build/
/docs/Manifest.toml

# LaTeX manual — keep the .tex source, ignore the compiled PDF and aux files
/docs/manual/EDGAR.pdf
/docs/manual/*.aux
/docs/manual/*.log
/docs/manual/*.out
/docs/manual/*.toc
/docs/manual/*.fls
/docs/manual/*.fdb_latexmk
texput.log

# Secrets — NEVER commit (SSH deploy keys, tokens). Not needed for the
# GitHub-Actions Pages deploy; safe to delete locally.
/.github/edgar_doc_deploy_key
/.github/edgar_doc_deploy_key.*

# On-disk HTTP response cache (created at runtime by fetch_url)
/.edgar_cache/

# Raw ESEF report packages — multi-MB downloads kept locally for debugging/regeneration.
# The committed offline fixture is a small derived package in test/data/esef/ (not under raw/).
/test/data/esef/raw/

# Claude Code local agent dir (settings, transcripts) — not part of the package
/.claude/

# Julia
*.jl.cov
*.jl.*.cov
*.jl.mem
.DS_Store

# Package Manifest — resolve fresh in CI (this is a library, not an app)
/Manifest.toml

# Output of scripts/filings_lifecycle.jl demo
filings_demo/
