# Documenter build output + resolved docs environment (regenerated each build)
/docs/build/
/docs/Manifest.toml

# Secrets — NEVER commit (SSH deploy keys, tokens). Not needed for the
# GitHub-Actions Pages deploy; safe to delete locally.
/.github/edgar_doc_deploy_key
/.github/edgar_doc_deploy_key.*

# On-disk HTTP response cache (created at runtime by fetch_url)
/.edgar_cache/

# Julia
*.jl.cov
*.jl.*.cov
*.jl.mem
.DS_Store

# Package Manifest — resolve fresh in CI (this is a library, not an app)
/Manifest.toml
